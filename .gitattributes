# .gitattributes — normalize line endings and tag binary files
# https://git-scm.com/docs/gitattributes

# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Source code — explicit text
*.py        text eol=lf diff=python
*.sh        text eol=lf
*.bash      text eol=lf
*.bats      text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf

# Windows-only scripts must stay CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binaries — never normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary

# Linguist overrides — exclude generated/vendored from language stats
dashboard/data.json     linguist-generated=true
sessions/**             linguist-generated=true
logs/**                 linguist-generated=true

# Exclude from GitHub release archives (export-ignore)
.github/                export-ignore
.gitattributes          export-ignore
.gitignore              export-ignore
.editorconfig           export-ignore
tests/                  export-ignore
AUDIT-PRE-DEPLOY.md     export-ignore
