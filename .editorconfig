# EditorConfig — https://editorconfig.org
# Top-most EditorConfig file
root = true

# Defaults for all files
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

# Markdown — preserve trailing whitespace (line breaks)
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Python — PEP 8
[*.py]
indent_size = 4
max_line_length = 100

# Shell scripts — POSIX, LF only
[*.{sh,bash}]
indent_size = 2
end_of_line = lf

# JSON / YAML / TOML
[*.{json,yaml,yml,toml}]
indent_size = 2

# Bats tests
[*.bats]
indent_size = 2

# Makefile — tabs required
[Makefile]
indent_style = tab

# Windows batch files (preserve CRLF)
[*.{bat,cmd}]
end_of_line = crlf
